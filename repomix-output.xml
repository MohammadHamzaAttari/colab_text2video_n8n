print(f"  📋  Job list      : {public_url}/jobs")
print(f"\n  🎥  Model         : {os.environ['MODEL_ID']}")
print(f"  ⚡  Checkpoint    : {os.environ['CKPT_ID']}")
print(f"  🖥️   GPU VRAM      : {vram_gb:.1f} GB")

print("""
