    {
      "parameters": {
        "jsCode": "// Store both job_id AND original request data\nreturn items.map(item => ({\n  json: {\n    job_id: item.json.job_id,\n    status: item.json.status || 'queued',\n    original_data: $('Prepare Rows').item.json,\n    poll_count: 0\n  }\n}));"
      },
