    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const pollingResponse = item.json;\n  const previousData = $('Wait 20 Seconds').item.json;\n  \n  return {\n    json: {\n      job_id: previousData.job_id,\n      original_data: previousData.original_data,\n      poll_count: (previousData.poll_count || 0) + 1,\n      status: pollingResponse.status,\n      video_url: pollingResponse.video_url,\n      file_name: pollingResponse.file_name,\n      file_path: pollingResponse.file_path,\n      seed: pollingResponse.seed,\n      generation_time: pollingResponse.generation_time,\n      error: pollingResponse.error\n    }\n  };\n});"
      },
      "id": "73dd29a4-2a36-4662-be2d-1fe12c1806dd",
      "name": "Merge Poll Response",
