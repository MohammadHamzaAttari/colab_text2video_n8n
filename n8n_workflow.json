        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({\n  prompt: $json.prompt,\n  negative_prompt: $json.negative_prompt,\n  seed: $json.seed,\n  num_frames: $json.num_frames,\n  num_inference_steps: $json.num_inference_steps,\n  guidance_scale: $json.guidance_scale,\n  width: $json.width,\n  height: $json.height,\n  fps: $json.fps,\n  subfolder: $json.subfolder,\n  filename_prefix: $json.filename_prefix\n}) }}",
        "options": {
