    {
      "parameters": {
        "command": "={{ 'mkdir -p \"$HOME/video/' + $json.safe_folder + '\" && curl -L --fail --retry 3 \"' + $json.video_url + '\" -o \"$HOME/video/' + $json.safe_folder + '/' + $json.safe_file + '\" && echo \"✅ Saved: $HOME/video/' + $json.safe_folder + '/' + $json.safe_file + ' (seed: ' + $json.seed + ', time: ' + $json.generation_time + 's)\"' }}"
      },
